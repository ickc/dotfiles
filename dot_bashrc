#!/usr/bin/env bash
# Bash entry point. Bash has no separate env file, so source the shared env
# directly; when interactive, source distro globals then the shared interactive
# rc (which also starts the ssh-agent, shared with zsh).

# shellcheck source=dot_config/sh/env.sh
. "${XDG_CONFIG_HOME:-${HOME}/.config}/sh/env.sh"

if [[ $- == *i* ]]; then
    # Source global definitions (some distros, e.g. RHEL, ship these in /etc/bashrc)
    if [[ -f /etc/bashrc ]]; then
        . /etc/bashrc
    fi
    # shellcheck source=dot_config/sh/rc.sh
    . "${XDG_CONFIG_HOME:-${HOME}/.config}/sh/rc.sh"
fi
