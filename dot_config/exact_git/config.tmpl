[user]
        name = Kolen Cheung
        email = {{ .email }}
[pull]
        rebase = false
[filter "lfs"]
        process = git-lfs filter-process
        required = true
        clean = git-lfs clean -- %f
        smudge = git-lfs smudge -- %f
[credential]
        helper = store
[rerere]
	enabled = true
[core]
	editor = code --wait
